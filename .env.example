# ─────────────────────────────────────────────────────────────
# Web App cho Claude Code — env mẫu
# Copy file này thành `.env` và sửa các giá trị bên dưới.
# ─────────────────────────────────────────────────────────────

# ── Backend (đọc bởi FastAPI) ────────────────────────────────
# URL kết nối Postgres. Format async: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/web_app_cho_claude_code

# Password admin để đăng nhập trang /admin. Đổi thành chuỗi khó đoán.
ADMIN_PASSWORD=change-me

# Origin của frontend được phép gọi backend qua CORS.
FRONTEND_ORIGIN=http://localhost:5173

# Secret để ký session cookie. Tạo bằng: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# ── Frontend (Vite chỉ đọc biến bắt đầu bằng VITE_) ──────────
# URL của backend mà frontend sẽ fetch.
VITE_API_URL=http://localhost:8000
